# Google OAuth credentials — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match the redirect URI registered in Google Cloud Console
REDIRECT_URI=http://localhost:5501/redirect

# Jarvis backend URL — use https://jarvis-demo.ascendingdc.com for the hosted demo
# or http://localhost:3080 when running Jarvis locally
JARVIS_URL=https://jarvis-demo.ascendingdc.com

# Optional: override the default spec
JARVIS_SPEC=

PORT=5500
